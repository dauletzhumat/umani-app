NODE_ENV=development
PORT=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_finance
POSTGRES_PASSWORD=ai_finance
POSTGRES_DB=ai_finance

# Dev-only value — override for staging/production.
JWT_SECRET=dev-only-insecure-secret-change-me

REDIS_HOST=localhost
REDIS_PORT=6379

# Leave empty to disable AI categorization (T4.4) without an API key.
OPENAI_API_KEY=

# Leave empty to disable OCR (T4.5) — scans return 503 AI_PROVIDER_UNAVAILABLE.
GOOGLE_VISION_API_KEY=
SUPABASE_URL=
